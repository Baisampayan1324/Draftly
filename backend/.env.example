# Backend Environment Variables
# Copy this to .env and fill in the values

# Groq API key for LLM
GROQ_API_KEY=your_groq_api_key_here

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# OAuth redirect URI - must match Google Cloud Console callback URL
# Local: http://localhost:8000/auth/gmail/callback
# Production: https://your-api-domain.onrender.com/auth/gmail/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# Frontend URL for redirects after OAuth
# Local: http://localhost:8080
# Production: https://your-frontend-domain.onrender.com
FRONTEND_URL=http://localhost:8080
